# ============================================================
# AIVibe Platform - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================================

# --- SUPABASE ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- AI PROVIDERS ---
# OpenRouter (primary AI provider)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Groq (fallback AI provider - super fast & cheap)
GROQ_API_KEY=gsk_your-groq-key

# --- STRIPE ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_ID_MONTHLY=price_your-monthly-price-id
STRIPE_PRICE_ID_YEARLY=price_your-yearly-price-id

# --- APP ---
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_APP_NAME=AIVibe
NEXT_PUBLIC_APP_DESCRIPTION=Viral AI identity and creator tools for everyone

# --- ANALYTICS ---
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_CLARITY_PROJECT_ID=your-clarity-id

# --- ADSENSE ---
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-your-adsense-id

# --- SECURITY ---
RATE_LIMIT_SECRET=your-random-secret-for-rate-limiting
CRON_SECRET=your-secret-for-cron-jobs

# --- STORAGE ---
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=aivibe-public

# --- SITE ---
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
